# 📂 Directory Penyimpanan
# Defalut: laporan_keuangan
OUTPUT_DIR=laporan_keuangan

# 🚀 Konfigurasi Kecepatan & Stabilitas
CONCURRENCY_LIMIT=5
META_CONCURRENCY=1

# 🧘 Konfigurasi Cooldown (Jeda)
# Batch size: jumlah emiten sebelum istirahat
BATCH_SIZE=20
# Durasi istirahat dalam detik
BATCH_COOLDOWN=60
